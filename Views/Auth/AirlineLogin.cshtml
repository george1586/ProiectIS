@* @model ProjIS.Models.ViewModels.AirlineLoginViewModel *@

@{
    ViewData["Title"] = "Airline Login";
}

<section class="auth-section">
    <div class="auth-card">

        <div class="auth-card__header">
            <div class="auth-card__icon">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M4 20L14 4L24 20H16L14 24L12 20H4Z" fill="#F5A623"/>
                </svg>
            </div>
            <h1 class="auth-card__title">Airline Portal</h1>
            <p class="auth-card__subtitle">Sign in to manage your flights</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert--error">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M8 5v3M8 11h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                <span>
                    @Html.ValidationSummary(false, "", new { @class = "validation-summary" })
                </span>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert--error">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M8 5v3M8 11h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                <span>@TempData["Error"]</span>
            </div>
        }

        <form asp-controller="Auth" asp-action="AirlineLogin" method="post" class="auth-form" novalidate>
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label" asp-for="Name">Airline name</label>
                <input asp-for="Name"
                       class="input"
                       type="text"
                       placeholder="e.g. TAROM, Wizz Air"
                       autocomplete="organization" />
                <span asp-validation-for="Name" class="field-error"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Password">Password</label>
                <div class="input-password-wrap">
                    <input asp-for="Password"
                           class="input"
                           id="passwordInput"
                           type="password"
                           placeholder="Enter your password"
                           autocomplete="current-password" />
                    <button type="button" class="password-toggle" onclick="togglePassword()" aria-label="Toggle password visibility">
                        <svg id="eyeIcon" width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M1 9s3-6 8-6 8 6 8 6-3 6-8 6-8-6-8-6z" stroke="currentColor" stroke-width="1.5"/>
                            <circle cx="9" cy="9" r="2.5" stroke="currentColor" stroke-width="1.5"/>
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <button type="submit" class="btn btn-primary btn--full">
                Sign in
            </button>

        </form>

        <p class="auth-card__back">
            <a href="/">← Back to flight search</a>
        </p>

    </div>
</section>

<style>
    .auth-section {
        min-height: calc(100vh - var(--nav-height) - 60px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: var(--space-12) var(--space-4);
    }

    .auth-card {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-xl);
        padding: var(--space-10);
        width: 100%;
        max-width: 420px;
        box-shadow: var(--shadow-lg);
    }

    .auth-card__header {
        text-align: center;
        margin-bottom: var(--space-8);
    }

    .auth-card__icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 56px;
        height: 56px;
        background: var(--color-primary);
        border-radius: var(--radius-lg);
        margin-bottom: var(--space-4);
    }

    .auth-card__title {
        font-family: var(--font-display);
        font-size: var(--text-2xl);
        color: var(--color-primary);
        margin-bottom: var(--space-2);
    }

    .auth-card__subtitle {
        font-size: var(--text-sm);
        color: var(--color-text-secondary);
    }

    .auth-form {
        display: flex;
        flex-direction: column;
        gap: var(--space-5);
    }

    .auth-form .form-group {
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
    }

    .input-password-wrap {
        position: relative;
    }

    .input-password-wrap .input {
        padding-right: var(--space-10);
    }

    .password-toggle {
        position: absolute;
        right: var(--space-3);
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        color: var(--color-text-muted);
        display: flex;
        align-items: center;
        padding: 0;
        transition: color var(--transition-fast);
    }

    .password-toggle:hover {
        color: var(--color-text-secondary);
    }

    .btn--full {
        width: 100%;
        padding: var(--space-4);
        font-size: var(--text-base);
        margin-top: var(--space-2);
    }

    .alert {
        display: flex;
        align-items: flex-start;
        gap: var(--space-3);
        padding: var(--space-3) var(--space-4);
        border-radius: var(--radius-md);
        font-size: var(--text-sm);
        margin-bottom: var(--space-5);
    }

    .alert--error {
        background: var(--color-error-bg);
        color: var(--color-error);
        border: 1px solid rgba(239, 68, 68, 0.2);
    }

    .alert svg {
        flex-shrink: 0;
        margin-top: 1px;
    }

    .field-error {
        font-size: var(--text-xs);
        color: var(--color-error);
        margin-top: var(--space-1);
    }

    .auth-card__back {
        text-align: center;
        margin-top: var(--space-6);
        font-size: var(--text-sm);
    }

    .auth-card__back a {
        color: var(--color-text-secondary);
        transition: color var(--transition-fast);
    }

    .auth-card__back a:hover {
        color: var(--color-primary);
    }
</style>

<script>
    function togglePassword() {
        const input = document.getElementById('passwordInput');
        const icon = document.getElementById('eyeIcon');
        const isHidden = input.type === 'password';

        input.type = isHidden ? 'text' : 'password';

        icon.innerHTML = isHidden
            ? `<path d="M2 2l14 14M7.5 7.7A2.5 2.5 0 0111.3 11M6.3 6A8.8 8.8 0 001 9s3 6 8 6a8.7 8.7 0 004.7-1.4M9.9 4.1A8.5 8.5 0 0117 9s-3 6-8 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`
            : `<path d="M1 9s3-6 8-6 8 6 8 6-3 6-8 6-8-6-8-6z" stroke="currentColor" stroke-width="1.5"/><circle cx="9" cy="9" r="2.5" stroke="currentColor" stroke-width="1.5"/>`;
    }
</script>