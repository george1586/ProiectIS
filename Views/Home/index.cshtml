@{
    ViewData["Title"] = "Search Flights";
}

<!-- HERO -->
<section class="hero">
    <div class="hero__backdrop"></div>
    <div class="container hero__content">
        <p class="hero__eyebrow">Book with confidence</p>
        <h1 class="hero__title">Where do you want<br>to fly today?</h1>

        <!-- SEARCH CARD -->
        <div class="search-card">

            <!-- Trip type toggle -->
            <div class="trip-toggle">
                <button type="button" class="trip-toggle__btn trip-toggle__btn--active" id="btn-oneway"
                    onclick="setTripType('oneway')">
                    One way
                </button>
                <button type="button" class="trip-toggle__btn" id="btn-roundtrip" onclick="setTripType('roundtrip')">
                    Round trip
                    <span class="badge badge-roundtrip" style="margin-left: 6px; font-size: 11px;">-5%</span>
                </button>
            </div>

            <form asp-controller="Flight" asp-action="Search" method="post" class="search-form">
                <input type="hidden" name="IsRoundTrip" id="isRoundTrip" value="false" />

                <div class="search-form__row">

                    <!-- Departure -->
                    <div class="form-group">
                        <label class="form-label" for="departure">From</label>
                        <div class="input-icon-wrap">
                            <svg class="input-icon" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="10" cy="9" r="4" stroke="currentColor" stroke-width="1.5" />
                                <path d="M10 2v2M10 16v2M2 10h2M16 10h2" stroke="currentColor" stroke-width="1.5"
                                    stroke-linecap="round" />
                            </svg>
                            <input type="text" class="input" id="departure" name="DepartureCity"
                                placeholder="City or airport" required />
                        </div>
                    </div>

                    <!-- Swap button -->
                    <button type="button" class="swap-btn" onclick="swapCities()" title="Swap cities">
                        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M3 6h12M3 6l3-3M3 6l3 3M15 12H3M15 12l-3-3M15 12l-3 3" stroke="currentColor"
                                stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </button>

                    <!-- Destination -->
                    <div class="form-group">
                        <label class="form-label" for="destination">To</label>
                        <div class="input-icon-wrap">
                            <svg class="input-icon" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M10 2C7.24 2 5 4.24 5 7c0 4.25 5 11 5 11s5-6.75 5-11c0-2.76-2.24-5-5-5z"
                                    stroke="currentColor" stroke-width="1.5" />
                                <circle cx="10" cy="7" r="1.5" fill="currentColor" />
                            </svg>
                            <input type="text" class="input" id="destination" name="DestinationCity"
                                placeholder="City or airport" required />
                        </div>
                    </div>

                    <!-- Date -->
                    <div class="form-group">
                        <label class="form-label" for="depDate">Departure date</label>
                        <input type="date" class="input" id="depDate" name="DepartureDate" required />
                    </div>

                    <!-- Return date (hidden by default) -->
                    <div class="form-group" id="returnDateGroup" style="display: none;">
                        <label class="form-label" for="retDate">Return date</label>
                        <input type="date" class="input" id="retDate" name="ReturnDate" />
                    </div>

                    <!-- Passengers -->
                    <div class="form-group">
                        <label class="form-label" for="passengers">Passengers</label>
                        <input type="number" class="input" id="passengers" name="PassengerCount" min="1" max="50"
                            value="1" required />
                    </div>

                </div>

                <div class="search-form__footer">
                    <button type="submit" class="btn btn-primary btn--search">
                        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="8" cy="8" r="5.5" stroke="currentColor" stroke-width="1.5" />
                            <path d="M12.5 12.5L16 16" stroke="currentColor" stroke-width="1.5"
                                stroke-linecap="round" />
                        </svg>
                        Search flights
                    </button>
                </div>

            </form>
        </div>
    </div>
</section>

<!-- HOW IT WORKS -->
<section class="how-it-works">
    <div class="container">
        <h2 class="section-title">How it works</h2>
        <div class="steps">

            <div class="step">
                <div class="step__number">01</div>
                <h3 class="step__title">Search</h3>
                <p class="step__desc">Enter your departure city, destination, travel date and number of passengers.</p>
            </div>

            <div class="step__divider"></div>

            <div class="step">
                <div class="step__number">02</div>
                <h3 class="step__title">Choose</h3>
                <p class="step__desc">Browse available flights by class — economy, business or first. See seats and
                    prices instantly.</p>
            </div>

            <div class="step__divider"></div>

            <div class="step">
                <div class="step__number">03</div>
                <h3 class="step__title">Book</h3>
                <p class="step__desc">Fill in your details, add extras like meals or luggage, and pay by card or cash.
                </p>
            </div>

        </div>
    </div>
</section>

<!-- DISCOUNTS STRIP -->
<section class="discounts-strip">
    <div class="container discounts-strip__inner">
        <div class="discount-item">
            <span class="badge badge-roundtrip">Round trip</span>
            <p>Book outbound and return together and save <strong>5%</strong> on the total fare.</p>
        </div>
        <div class="discount-divider"></div>
        <div class="discount-item">
            <span class="badge badge-lastminute">Last minute</span>
            <p>Flying within <strong>48 hours</strong>? You automatically get a <strong>40%</strong> discount.</p>
        </div>
    </div>
</section>


<!-- PAGE-SPECIFIC STYLES -->
<style>
    /* ── Hero ── */
    .hero {
        position: relative;
        background-color: var(--color-primary);
        padding: var(--space-20) 0 var(--space-16);
        overflow: hidden;
    }

    .hero__backdrop {
        position: absolute;
        inset: 0;
        background-image:
            radial-gradient(ellipse 80% 60% at 70% 40%, rgba(245, 166, 35, 0.08) 0%, transparent 70%),
            radial-gradient(ellipse 50% 80% at 10% 80%, rgba(245, 166, 35, 0.05) 0%, transparent 60%);
        pointer-events: none;
    }

    .hero__content {
        position: relative;
        z-index: 1;
    }

    .hero__eyebrow {
        font-family: var(--font-body);
        font-size: var(--text-sm);
        font-weight: var(--font-medium);
        color: var(--color-accent);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: var(--space-3);
    }

    .hero__title {
        font-family: var(--font-display);
        font-size: clamp(2rem, 5vw, 3.25rem);
        color: var(--color-white);
        line-height: 1.15;
        margin-bottom: var(--space-10);
    }

    /* ── Search card ── */
    .search-card {
        background: var(--color-white);
        border-radius: var(--radius-xl);
        padding: var(--space-8);
        box-shadow: var(--shadow-xl);
        max-width: 860px;
    }

    .trip-toggle {
        display: flex;
        gap: var(--space-2);
        margin-bottom: var(--space-6);
    }

    .trip-toggle__btn {
        display: inline-flex;
        align-items: center;
        padding: var(--space-2) var(--space-5);
        border: 2px solid var(--color-border);
        border-radius: var(--radius-full);
        background: transparent;
        font-family: var(--font-body);
        font-size: var(--text-sm);
        font-weight: var(--font-medium);
        color: var(--color-text-secondary);
        cursor: pointer;
        transition: all var(--transition-fast);
    }

    .trip-toggle__btn--active {
        border-color: var(--color-primary);
        background: var(--color-primary);
        color: var(--color-white);
    }

    .search-form__row {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-4);
        align-items: flex-end;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
        flex: 1;
        min-width: 140px;
    }

    .form-label {
        font-size: var(--text-xs);
        font-weight: var(--font-semibold);
        color: var(--color-text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .input-icon-wrap {
        position: relative;
    }

    .input-icon-wrap .input {
        padding-left: var(--space-10);
    }

    .input-icon {
        position: absolute;
        left: var(--space-3);
        top: 50%;
        transform: translateY(-50%);
        width: 16px;
        height: 16px;
        color: var(--color-text-muted);
        pointer-events: none;
    }

    .swap-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 38px;
        height: 38px;
        border-radius: var(--radius-full);
        border: 2px solid var(--color-border);
        background: var(--color-background);
        color: var(--color-text-secondary);
        cursor: pointer;
        transition: all var(--transition-fast);
        flex-shrink: 0;
        margin-bottom: 2px;
    }

    .swap-btn:hover {
        border-color: var(--color-accent);
        color: var(--color-accent);
    }

    .search-form__footer {
        margin-top: var(--space-6);
        display: flex;
        justify-content: flex-end;
    }

    .btn--search {
        padding: var(--space-3) var(--space-8);
        font-size: var(--text-base);
        gap: var(--space-2);
    }

    .btn--sm {
        padding: var(--space-2) var(--space-4);
        font-size: var(--text-sm);
    }

    /* ── How it works ── */
    .how-it-works {
        padding: var(--space-16) 0;
        background: var(--color-white);
    }

    .section-title {
        font-family: var(--font-display);
        font-size: var(--text-3xl);
        color: var(--color-primary);
        text-align: center;
        margin-bottom: var(--space-12);
    }

    .steps {
        display: flex;
        align-items: center;
        gap: var(--space-4);
        max-width: 760px;
        margin: 0 auto;
    }

    .step {
        flex: 1;
        text-align: center;
    }

    .step__number {
        font-family: var(--font-display);
        font-size: var(--text-4xl);
        color: var(--color-accent);
        font-weight: var(--font-bold);
        line-height: 1;
        margin-bottom: var(--space-3);
    }

    .step__title {
        font-family: var(--font-display);
        font-size: var(--text-xl);
        color: var(--color-primary);
        margin-bottom: var(--space-2);
    }

    .step__desc {
        font-size: var(--text-sm);
        color: var(--color-text-secondary);
        line-height: var(--leading-loose);
    }

    .step__divider {
        width: 60px;
        height: 1px;
        background: var(--color-border);
        flex-shrink: 0;
    }

    /* ── Discounts strip ── */
    .discounts-strip {
        background: var(--color-background);
        border-top: 1px solid var(--color-border);
        border-bottom: 1px solid var(--color-border);
        padding: var(--space-8) 0;
    }

    .discounts-strip__inner {
        display: flex;
        align-items: center;
        gap: var(--space-8);
    }

    .discount-item {
        display: flex;
        align-items: center;
        gap: var(--space-4);
        flex: 1;
        font-size: var(--text-sm);
        color: var(--color-text-secondary);
    }

    .discount-divider {
        width: 1px;
        height: 40px;
        background: var(--color-border);
        flex-shrink: 0;
    }
</style>

<script>
    function setTripType(type) {
        const isRound = type === 'roundtrip';
        document.getElementById('isRoundTrip').value = isRound;
        document.getElementById('returnDateGroup').style.display = isRound ? 'flex' : 'none';
        document.getElementById('btn-oneway').classList.toggle('trip-toggle__btn--active', !isRound);
        document.getElementById('btn-roundtrip').classList.toggle('trip-toggle__btn--active', isRound);
    }

    function swapCities() {
        const dep = document.getElementById('departure');
        const dest = document.getElementById('destination');
        const temp = dep.value;
        dep.value = dest.value;
        dest.value = temp;
    }

    // Set today as minimum date for departure
    document.addEventListener('DOMContentLoaded', function () {
        const today = new Date().toISOString().split('T')[0];
        document.getElementById('depDate').min = today;
        document.getElementById('retDate').min = today;

        document.getElementById('depDate').addEventListener('change', function () {
            document.getElementById('retDate').min = this.value;
        });
    });
</script>