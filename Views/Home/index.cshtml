@{
    ViewData["Title"] = "SkyGate";
}

<section style="background: var(--color-primary); padding: var(--space-20) 0 var(--space-16) 0;">
    <div class="container">

        <p style="
            color: var(--color-accent);
            font-size: var(--text-sm);
            font-weight: var(--font-bold);
            letter-spacing: 2px;
            margin-bottom: var(--space-4);
        ">
            BOOK WITH CONFIDENCE
        </p>

        <h1 style="
            color: var(--color-white);
            font-size: 4rem;
            max-width: 650px;
            margin-bottom: var(--space-10);
        ">
            Where do you want<br />
            to fly today?
        </h1>

        @if (TempData["Error"] != null)
        {
            <div class="card" style="
                background: var(--color-error-bg);
                color: var(--color-error);
                margin-bottom: var(--space-6);
            ">
                @TempData["Error"]
            </div>
        }

        <div class="card" style="
            max-width: 900px;
            padding: var(--space-8);
            border-radius: var(--radius-xl);
            box-shadow: var(--shadow-xl);
        ">

            <div style="
                display: flex;
                align-items: center;
                gap: var(--space-3);
                margin-bottom: var(--space-8);
            ">
                <button type="button" id="oneWayBtn" class="btn btn-secondary">
                    One way
                </button>

                <button type="button" id="roundTripBtn" class="btn btn-outline">
                    Round trip
                    <span class="badge badge-roundtrip" style="margin-left: 6px;">
                        -5%
                    </span>
                </button>
            </div>

            <form action="/Passenger/Results" method="get">
                <input type="hidden" id="isRoundTripInput" name="IsRoundTrip" value="false" />

                <div style="
                    display: grid;
                    grid-template-columns: 1fr 1fr 1fr 1fr;
                    gap: var(--space-4);
                    align-items: end;
                ">

                    <div>
                        <label style="
                            display: block;
                            font-size: var(--text-xs);
                            font-weight: var(--font-bold);
                            color: var(--color-text-secondary);
                            letter-spacing: 1px;
                            margin-bottom: var(--space-2);
                        ">
                            FROM
                        </label>

                        <input
                            class="input"
                            name="DepartureCity"
                            placeholder="City or airport"
                            required />
                    </div>

                    <div>
                        <label style="
                            display: block;
                            font-size: var(--text-xs);
                            font-weight: var(--font-bold);
                            color: var(--color-text-secondary);
                            letter-spacing: 1px;
                            margin-bottom: var(--space-2);
                        ">
                            TO
                        </label>

                        <input
                            class="input"
                            name="DestinationCity"
                            placeholder="City or airport"
                            required />
                    </div>

                    <div>
                        <label style="
                            display: block;
                            font-size: var(--text-xs);
                            font-weight: var(--font-bold);
                            color: var(--color-text-secondary);
                            letter-spacing: 1px;
                            margin-bottom: var(--space-2);
                        ">
                            DEPARTURE DATE
                        </label>

                        <input
                            class="input"
                            name="DepartureDate"
                            type="date"
                            required />
                    </div>

                    <div>
                        <label style="
                            display: block;
                            font-size: var(--text-xs);
                            font-weight: var(--font-bold);
                            color: var(--color-text-secondary);
                            letter-spacing: 1px;
                            margin-bottom: var(--space-2);
                        ">
                            PASSENGERS
                        </label>

                        <input
                            class="input"
                            name="Passengers"
                            type="number"
                            min="1"
                            value="1"
                            required />
                    </div>
                </div>

                <div id="returnDateBox" style="
                    display: none;
                    margin-top: var(--space-4);
                    max-width: 230px;
                ">
                    <label style="
                        display: block;
                        font-size: var(--text-xs);
                        font-weight: var(--font-bold);
                        color: var(--color-text-secondary);
                        letter-spacing: 1px;
                        margin-bottom: var(--space-2);
                    ">
                        RETURN DATE
                    </label>

                    <input
                        id="returnDateInput"
                        class="input"
                        name="ReturnDate"
                        type="date" />
                </div>

                <div style="
                    display: flex;
                    justify-content: flex-end;
                    margin-top: var(--space-6);
                ">
                    <button type="submit" class="btn btn-primary" style="min-width: 190px;">
                        Search flights
                    </button>
                </div>
            </form>
        </div>
    </div>
</section>

<section style="background: var(--color-white); padding: var(--space-16) 0;">
    <div class="container">
        <h2 style="
            text-align: center;
            margin-bottom: var(--space-12);
        ">
            How it works
        </h2>

        <div style="
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: var(--space-8);
            text-align: center;
        ">
            <div>
                <p style="
                    color: var(--color-accent);
                    font-size: var(--text-3xl);
                    font-family: var(--font-display);
                    font-weight: var(--font-bold);
                    margin-bottom: var(--space-2);
                ">
                    01
                </p>

                <h3 style="margin-bottom: var(--space-3);">
                    Search
                </h3>

                <p style="color: var(--color-text-secondary);">
                    Enter your departure city, destination, travel date and number of passengers.
                </p>
            </div>

            <div>
                <p style="
                    color: var(--color-accent);
                    font-size: var(--text-3xl);
                    font-family: var(--font-display);
                    font-weight: var(--font-bold);
                    margin-bottom: var(--space-2);
                ">
                    02
                </p>

                <h3 style="margin-bottom: var(--space-3);">
                    Choose
                </h3>

                <p style="color: var(--color-text-secondary);">
                    Browse available flights by class: economy, business or first class.
                </p>
            </div>

            <div>
                <p style="
                    color: var(--color-accent);
                    font-size: var(--text-3xl);
                    font-family: var(--font-display);
                    font-weight: var(--font-bold);
                    margin-bottom: var(--space-2);
                ">
                    03
                </p>

                <h3 style="margin-bottom: var(--space-3);">
                    Book
                </h3>

                <p style="color: var(--color-text-secondary);">
                    Fill in your details, add extras and pay by card or cash.
                </p>
            </div>
        </div>
    </div>
</section>

<section style="background: var(--color-background); padding: var(--space-8) 0;">
    <div class="container">
        <div class="card" style="
            display: flex;
            justify-content: space-between;
            gap: var(--space-8);
        ">
            <p>
                <span class="badge badge-roundtrip">Round trip</span>
                Book outbound and return together and save <strong>5%</strong> on the total fare.
            </p>

            <p>
                <span class="badge badge-lastminute">Last minute</span>
                Flying within <strong>48 hours</strong>? You automatically get a <strong>40%</strong> discount.
            </p>
        </div>
    </div>
</section>

<script>
    const oneWayBtn = document.getElementById("oneWayBtn");
    const roundTripBtn = document.getElementById("roundTripBtn");
    const isRoundTripInput = document.getElementById("isRoundTripInput");
    const returnDateBox = document.getElementById("returnDateBox");
    const returnDateInput = document.getElementById("returnDateInput");

    oneWayBtn.addEventListener("click", function () {
        isRoundTripInput.value = "false";

        oneWayBtn.className = "btn btn-secondary";
        roundTripBtn.className = "btn btn-outline";

        returnDateBox.style.display = "none";
        returnDateInput.required = false;
        returnDateInput.value = "";
    });

    roundTripBtn.addEventListener("click", function () {
        isRoundTripInput.value = "true";

        roundTripBtn.className = "btn btn-secondary";
        oneWayBtn.className = "btn btn-outline";

        returnDateBox.style.display = "block";
        returnDateInput.required = true;
    });
</script>