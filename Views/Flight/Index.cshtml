@model List<ProjIS.Models.Flight>

@{
    ViewData["Title"] = "My Flights";
}

<section class="dashboard">
    <div class="container">

        <div class="dashboard__header">
            <div>
                <h1 class="dashboard__title">My Flights</h1>
                <p class="dashboard__subtitle">Welcome, @User.Identity?.Name</p>
            </div>
            <div class="dashboard__actions">
                <a href="/Flight/Create" class="btn btn-primary">+ Add flight</a>
                <form asp-controller="Auth" asp-action="Logout" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline">Logout</button>
                </form>
            </div>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert--success">@TempData["Success"]</div>
        }

        @if (!Model.Any())
        {
            <div class="empty-state">
                <p>No flights yet. Click <strong>+ Add flight</strong> to get started.</p>
            </div>
        }
        else
        {
            <div class="flights-table">
                <table>
                    <thead>
                        <tr>
                            <th>Route</th>
                            <th>Plane</th>
                            <th>From → To</th>
                            <th>Type</th>
                            <th>Seats (E / B / F)</th>
                            <th>Time</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var f in Model)
                        {
                            <tr>
                                <td><code>@f.RouteCode</code></td>
                                <td>@f.PlaneModel</td>
                                <td>@f.DepartureCity → @f.DestinationCity</td>
                                <td>
                                    @if (f.FlightType == ProjIS.Models.FlightType.Seasonal)
                                    {
                                        <span class="badge badge-info">Seasonal</span>
                                        <small>@f.SeasonStart - @f.SeasonEnd</small>
                                    }
                                    else
                                    {
                                        <span class="badge badge-success">Regular</span>
                                    }
                                </td>
                                <td>@f.EconomySeats / @f.BusinessSeats / @f.FirstClassSeats</td>
                                <td>@f.DepartureTime.ToString("HH:mm")</td>
                                <td>
                                    <form asp-action="Delete" asp-route-id="@f.Id" method="post"
                                          onsubmit="return confirm('Delete flight @f.RouteCode?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-link btn-link--danger">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>

<style>
    .dashboard { padding: var(--space-12) 0; }
    .dashboard__header {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: var(--space-8);
    }
    .dashboard__title {
        font-family: var(--font-display); font-size: var(--text-3xl);
        color: var(--color-primary);
    }
    .dashboard__subtitle {
        color: var(--color-text-secondary); margin-top: var(--space-1);
        font-size: var(--text-sm);
    }
    .dashboard__actions { display: flex; gap: var(--space-3); }

    .alert--success {
        background: var(--color-success-bg); color: var(--color-success);
        padding: var(--space-3) var(--space-4); border-radius: var(--radius-md);
        margin-bottom: var(--space-6); font-size: var(--text-sm);
    }

    .empty-state {
        background: var(--color-surface); border: 2px dashed var(--color-border);
        border-radius: var(--radius-lg); padding: var(--space-12);
        text-align: center; color: var(--color-text-secondary);
    }

    .flights-table {
        background: var(--color-surface); border: 1px solid var(--color-border);
        border-radius: var(--radius-lg); overflow: hidden;
    }
    .flights-table table { width: 100%; border-collapse: collapse; }
    .flights-table th {
        text-align: left; padding: var(--space-4); font-size: var(--text-xs);
        font-weight: var(--font-semibold); color: var(--color-text-secondary);
        text-transform: uppercase; letter-spacing: 0.06em;
        border-bottom: 1px solid var(--color-border); background: var(--color-background);
    }
    .flights-table td {
        padding: var(--space-4); font-size: var(--text-sm);
        border-bottom: 1px solid var(--color-border);
    }
    .flights-table tr:last-child td { border-bottom: none; }
    .flights-table code {
        font-family: var(--font-mono); background: var(--color-background);
        padding: 2px 8px; border-radius: var(--radius-sm); font-size: var(--text-xs);
    }
    .flights-table small {
        display: block; color: var(--color-text-muted); font-size: var(--text-xs);
        margin-top: 4px;
    }

    .btn-link {
        background: none; border: none; cursor: pointer;
        font-size: var(--text-sm); color: var(--color-text-secondary);
        text-decoration: underline;
    }
    .btn-link--danger { color: var(--color-error); }
    .btn-link:hover { opacity: 0.7; }
</style>