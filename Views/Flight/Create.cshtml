@model ProjIS.Models.ViewModels.FlightCreateViewModel
@using ProjIS.Models

@{
    ViewData["Title"] = "Add Flight";
}

<section class="form-page">
    <div class="container form-page__container">

        <a href="/Flight" class="back-link">← Back to my flights</a>

        <h1 class="form-page__title">Add a flight</h1>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert--error">
                @Html.ValidationSummary(false)
            </div>
        }

        <form asp-action="Create" method="post" class="flight-form">
            @Html.AntiForgeryToken()

            <fieldset class="form-fieldset">
                <legend>Route</legend>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="RouteCode" class="form-label">Route code</label>
                        <input asp-for="RouteCode" class="input" placeholder="e.g. RO101" />
                        <span asp-validation-for="RouteCode" class="field-error"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="PlaneModel" class="form-label">Plane model</label>
                        <input asp-for="PlaneModel" class="input" placeholder="e.g. Boeing 737" />
                        <span asp-validation-for="PlaneModel" class="field-error"></span>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="DepartureCity" class="form-label">Departure city</label>
                        <input asp-for="DepartureCity" class="input" placeholder="e.g. Bucharest" />
                    </div>
                    <div class="form-group">
                        <label asp-for="DestinationCity" class="form-label">Destination city</label>
                        <input asp-for="DestinationCity" class="input" placeholder="e.g. London" />
                    </div>
                </div>
            </fieldset>

            <fieldset class="form-fieldset">
                <legend>Seats per class</legend>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="EconomySeats" class="form-label">Economy</label>
                        <input asp-for="EconomySeats" class="input" type="number" min="0" />
                    </div>
                    <div class="form-group">
                        <label asp-for="BusinessSeats" class="form-label">Business</label>
                        <input asp-for="BusinessSeats" class="input" type="number" min="0" />
                    </div>
                    <div class="form-group">
                        <label asp-for="FirstClassSeats" class="form-label">First class</label>
                        <input asp-for="FirstClassSeats" class="input" type="number" min="0" />
                    </div>
                </div>
            </fieldset>

            <fieldset class="form-fieldset">
                <legend>Price per class</legend>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="EconomyPrice" class="form-label">Economy (€)</label>
                        <input asp-for="EconomyPrice" class="input" type="number" step="0.01" min="0" />
                    </div>
                    <div class="form-group">
                        <label asp-for="BusinessPrice" class="form-label">Business (€)</label>
                        <input asp-for="BusinessPrice" class="input" type="number" step="0.01" min="0" />
                    </div>
                    <div class="form-group">
                        <label asp-for="FirstClassPrice" class="form-label">First class (€)</label>
                        <input asp-for="FirstClassPrice" class="input" type="number" step="0.01" min="0" />
                    </div>
                </div>
            </fieldset>

            <fieldset class="form-fieldset">
                <legend>Schedule</legend>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="FlightType" class="form-label">Flight type</label>
                        <select asp-for="FlightType" class="input" id="flightType" onchange="toggleSeason()">
                            <option value="@FlightType.Regular">Regular</option>
                            <option value="@FlightType.Seasonal">Seasonal</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label asp-for="DepartureTime" class="form-label">Departure time</label>
                        <input asp-for="DepartureTime" class="input" type="time" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Days of week</label>
                    <div class="days-grid">
                        @{
                            var dayNames = new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" };
                        }
                        @for (int i = 1; i <= 7; i++)
                        {
                            var dayValue = i;
                            <label class="day-checkbox">
                                <input type="checkbox" name="DaysOfWeek" value="@dayValue"
                                       @(Model.DaysOfWeek.Contains(dayValue) ? "checked" : "") />
                                <span>@dayNames[i - 1]</span>
                            </label>
                        }
                    </div>
                </div>

                <div id="seasonFields" class="form-row" style="display: none;">
                    <div class="form-group">
                        <label asp-for="SeasonStart" class="form-label">Season start</label>
                        <input asp-for="SeasonStart" class="input" type="date" />
                    </div>
                    <div class="form-group">
                        <label asp-for="SeasonEnd" class="form-label">Season end</label>
                        <input asp-for="SeasonEnd" class="input" type="date" />
                    </div>
                </div>
            </fieldset>

            <div class="form-actions">
                <a href="/Flight" class="btn btn-outline">Cancel</a>
                <button type="submit" class="btn btn-primary">Save flight</button>
            </div>
        </form>
    </div>
</section>

<style>
    .form-page { padding: var(--space-12) 0; }
    .form-page__container { max-width: 800px; }
    .form-page__title {
        font-family: var(--font-display); font-size: var(--text-3xl);
        color: var(--color-primary); margin-bottom: var(--space-8);
    }

    .back-link {
        display: inline-block; margin-bottom: var(--space-4);
        color: var(--color-text-secondary); font-size: var(--text-sm);
    }

    .flight-form { display: flex; flex-direction: column; gap: var(--space-6); }

    .form-fieldset {
        background: var(--color-surface); border: 1px solid var(--color-border);
        border-radius: var(--radius-lg); padding: var(--space-6); display: flex;
        flex-direction: column; gap: var(--space-4);
    }
    .form-fieldset legend {
        padding: 0 var(--space-2); font-family: var(--font-display);
        font-size: var(--text-lg); color: var(--color-primary);
    }

    .form-row {
        display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: var(--space-4);
    }
    .form-group { display: flex; flex-direction: column; gap: var(--space-2); }
    .form-label {
        font-size: var(--text-xs); font-weight: var(--font-semibold);
        color: var(--color-text-secondary); text-transform: uppercase;
        letter-spacing: 0.06em;
    }
    .field-error { font-size: var(--text-xs); color: var(--color-error); }

    .days-grid { display: flex; flex-wrap: wrap; gap: var(--space-2); }
    .day-checkbox {
        display: flex; align-items: center; gap: var(--space-2);
        padding: var(--space-2) var(--space-4); border: 1px solid var(--color-border);
        border-radius: var(--radius-full); cursor: pointer; font-size: var(--text-sm);
        transition: all var(--transition-fast);
    }
    .day-checkbox:has(input:checked) {
        background: var(--color-primary); color: var(--color-white);
        border-color: var(--color-primary);
    }
    .day-checkbox input { margin: 0; }

    .form-actions {
        display: flex; justify-content: flex-end; gap: var(--space-3);
        padding-top: var(--space-4);
    }

    .alert--error {
        background: var(--color-error-bg); color: var(--color-error);
        padding: var(--space-3) var(--space-4); border-radius: var(--radius-md);
    }
</style>

<script>
    function toggleSeason() {
        const type = document.getElementById('flightType').value;
        document.getElementById('seasonFields').style.display =
            type === 'Seasonal' ? 'grid' : 'none';
    }
    document.addEventListener('DOMContentLoaded', toggleSeason);
</script>